{
  "log": {
    "loglevel": "warning"
  },
  "api": {
    "tag": "api",
    "services": [
      "HandlerService",
      "LoggerService",
      "StatsService"
    ]
  },
  "inbounds": [
    {
      "tag": "api",
      "listen": "127.0.0.1",
      "port": 62789,
      "protocol": "tunnel",
      "settings": {
        "address": "127.0.0.1"
      }
    },
    {
      "tag": "clients",
      "listen": "0.0.0.0",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none",
        "fallbacks": [
          {
            "dest": "127.0.0.1:1010"
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "serverName": "DOMAIN",
          "minVersion": "1.2",
          "maxVersion": "1.3",
          "alpn": ["http/1.1"],
          "fingerprint": "chrome",
          "certificates": [
            {
              "certificateFile": "CERTIFICATE_FULLCHAIN",
              "keyFile": "CERTIFICATE_PRIVATE",
              "usage": "encipherment"
            }
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "exit",
      "protocol": "vless",
      "settings": {
        "address": "EXIT_IP",
        "port": 443,
        "id": "BRIDGE_CLIENT_ID",
        "flow": "xtls-rprx-vision",
        "encryption": "none"
      },
      "streamSettings": {
        "security": "reality",
        "realitySettings": {
          "publicKey": "PUBLIC_KEY",
          "fingerprint": "chrome",
          "serverName": "SNI",
          "shortId": "SHORT_ID",
          "spiderX": "/"
        }
      }
    }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "inboundTag": ["api"],
        "outboundTag": "api"
      },
      {
        "type": "field",
        "inboundTag": ["clients"],
        "outboundTag": "exit"
      }
    ]
  }
}
