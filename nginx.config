server {
    listen 127.0.0.1:1010;
    root /var/www/html;
    index index.html;
    location /add-user {
        proxy_pass http://127.0.0.1:7070;
        include proxy_params;
    }
    location /remove-user {
        proxy_pass http://127.0.0.1:7070;
        include proxy_params;
    }
    location / {
        try_files $uri $uri/ =404;
    }
}
