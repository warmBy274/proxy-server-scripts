server {
    listen 127.0.0.1:8080;
    root /var/www/html;
    index index.html;
    location / {
        try_files $uri $uri/ =404;
        expires 1d;
        add_header Cache-Control "public, no-transform";
    }
    location ~ /\. {
        deny all;
    }
    gzip on;
    gzip_types text/plain text/css application/javascript application/pdf;
    gzip_min_length 1000;
}
